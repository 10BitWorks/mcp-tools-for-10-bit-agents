{
  "name": "metamcp",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "dotenv -e .env.local turbo run dev",
    "dev:docker": "docker compose -f docker-compose.dev.yml up --build",
    "dev:docker:down": "docker compose -f docker-compose.dev.yml down",
    "dev:docker:clean": "docker compose -f docker-compose.dev.yml down -v --remove-orphans",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prettier": "^3.5.3",
    "turbo": "^2.9.14",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "@eslint/plugin-kit@<0.3.4": "^0.3.4",
      "ajv@6": "^6.14.0",
      "brace-expansion@1": "^1.1.13",
      "brace-expansion@2": "^2.0.3",
      "defu@<6.1.5": "^6.1.5",
      "esbuild@<0.25.0": "^0.25.0",
      "flatted@<3.4.2": "^3.4.2",
      "glob@10": "^10.5.0",
      "js-cookie@<3.0.7": "^3.0.7",
      "js-yaml@4": "^4.2.0",
      "lodash@<4.18.0": "^4.18.0",
      "minimatch@3": "^3.1.4",
      "minimatch@9": "^9.0.7",
      "path-to-regexp@8": "^8.4.0",
      "picomatch@2": "^2.3.2",
      "picomatch@4": "^4.0.4",
      "postcss@<8.5.10": "^8.5.10",
      "prismjs@<1.30.0": "^1.30.0",
      "qs@6": "^6.15.2",
      "rollup@4": "^4.59.0",
      "tar@7": "^7.5.16",
      "vite@7": "^7.3.5"
    }
  }
}
